# Auth service
AUTH_GRPC_PORT=50051
AUTH_HTTP_PORT=8080

# PostgreSQL — задайте пароль и DSN сами; для docker compose см. POSTGRES_PASSWORD ниже.
# Локально с compose (Postgres наружу на 5433): скопируйте в .env и выровняйте пароль с POSTGRES_PASSWORD.
POSTGRES_PASSWORD=changeme
POSTGRES_DSN=postgres://dealer:changeme@127.0.0.1:5433/dealer?sslmode=disable

# Redis
REDIS_ADDR=localhost:6379
REDIS_PASSWORD=
REDIS_DB=0

# Kafka
KAFKA_BROKERS=localhost:9092
KAFKA_TOPIC_AUTH_EVENTS=auth.events

# JWT
JWT_SECRET=your-super-secret-key-change-in-production
JWT_ACCESS_TTL=15m
JWT_REFRESH_TTL=168h
